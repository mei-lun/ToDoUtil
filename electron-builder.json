{
  "appId": "com.todoutil.app",
  "productName": "ToDoUtil",
  "directories": { "output": "release/${version}" },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "electron/assets/**/*"
  ],
  "extraResources": [
    { "from": "electron/assets", "to": "assets" }
  ],
  "win": {
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
